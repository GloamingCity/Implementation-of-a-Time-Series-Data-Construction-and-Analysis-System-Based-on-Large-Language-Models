# Copy this file to `.env` and fill in your credentials.
# The code reads these via the standard OpenAI SDK environment variables,
# so any OpenAI-compatible endpoint works (real OpenAI, Azure, local vLLM,
# or a reverse proxy your instructor gives you).

OPENAI_API_KEY=<YOUR_API_KEY_HERE>
OPENAI_BASE_URL=<YOUR_API_BASE_URL_HERE>   # e.g. https://api.openai.com/v1

# Models used by the eval pipeline.
# Override these if your endpoint exposes different names.
REFERENCE_MODEL=gpt-5.5
JUDGE_MODEL=gpt-5.4-mini
